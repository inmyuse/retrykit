{
  "name": "retrykit",
  "version": "0.1.0",
  "description": "Retry logic and circuit breakers with an identical API in Python and TypeScript.",
  "keywords": [
    "retry",
    "circuit-breaker",
    "backoff",
    "resilience",
    "opentelemetry",
    "async"
  ],
  "license": "MIT",
  "homepage": "https://github.com/inmyuse/retrykit",
  "repository": {
    "type": "git",
    "url": "https://github.com/inmyuse/retrykit.git",
    "directory": "typescript"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "lint": "eslint . --ext .ts"
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
